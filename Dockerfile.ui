FROM node:20-alpine AS builder

WORKDIR /app

COPY ui/package.json ui/package-lock.json* ./
# npm install (pas npm ci): aucun ui/package-lock.json n'est versionne, et npm ci
# echoue sans lockfile. Basculer sur npm ci une fois le lockfile commite.
RUN npm install

COPY ui/ .
RUN npm run build

FROM nginx:alpine

# Create non-root user (nginx already has 'nginx' user, we use it)
COPY --from=builder /app/dist /usr/share/nginx/html
COPY nginx.ui.conf /etc/nginx/conf.d/default.conf

EXPOSE 3000

HEALTHCHECK --interval=15s --timeout=5s --start-period=20s --retries=3 \
    CMD wget --spider -q http://localhost:3000/ || exit 1

USER nginx

CMD ["nginx", "-g", "daemon off;"]
